# ============================================================
# ECS – Evidence Collection System  |  Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# The backend (config.py) loads these at startup via python-dotenv.

# ----------------------------------------------------------
# Dify AI Integration
# ----------------------------------------------------------
# Your Dify app API key (found in Dify → App → API Access)
DIFY_API_KEY=app-rw1bC3Hb8TssMD6t0yqgouW9

# Dify base URL:
#   Cloud:       https://api.dify.ai/v1
#   Self-hosted: http://localhost/v1  (or your custom domain)
DIFY_BASE_URL=https://api.dify.ai/v1

# ----------------------------------------------------------
# Storage
# ----------------------------------------------------------
# Directory where uploaded evidence files are saved
UPLOAD_DIR=uploads
